extends SceneTree


func _initialize() -> void:
	var failures: Array[String] = []

	var inventory = load("res://scripts/inventory/Inventory.gd").new()
	_expect(inventory.get_count("carrot") == 0, "Inventory returns zero for missing items", failures)
	_expect(not inventory.has_item("carrot"), "Inventory has_item rejects missing items", failures)
	inventory.add_item("carrot", 2)
	inventory.add_item("carrot", 1)
	_expect(inventory.get_count("carrot") == 3, "Inventory stacks added items", failures)
	_expect(inventory.has_item("carrot", 3), "Inventory has_item accepts available items", failures)
	_expect(not inventory.has_item("carrot", 4), "Inventory has_item rejects unavailable amount", failures)
	_expect(inventory.get_all_items().get("carrot", 0) == 3, "Inventory returns all item counts", failures)
	inventory.add_item("", 10)
	inventory.add_item("carrot", 0)
	_expect(inventory.get_count("carrot") == 3, "Inventory ignores invalid additions", failures)
	_expect(inventory.remove_item("carrot", 2), "Inventory removes available items", failures)
	_expect(inventory.get_count("carrot") == 1, "Inventory count updates after removal", failures)
	_expect(not inventory.remove_item("carrot", 2), "Inventory rejects over-removal", failures)
	_expect(not inventory.remove_item("", 1), "Inventory rejects empty removal id", failures)
	_expect(not inventory.remove_item("carrot", 0), "Inventory rejects invalid removal amount", failures)

	var saved: Dictionary = inventory.to_dict()
	inventory.clear()
	_expect(inventory.get_all_items().is_empty(), "Inventory clears items", failures)
	inventory.from_dict(saved)
	_expect(inventory.get_count("carrot") == 1, "Inventory restores from dictionary", failures)
	inventory.from_dict({"carrot": 2, "stone": 0, "wood": -3})
	_expect(inventory.get_count("carrot") == 2, "Inventory restores positive counts", failures)
	_expect(not inventory.has_item("stone"), "Inventory ignores zero counts on restore", failures)
	_expect(not inventory.has_item("wood"), "Inventory ignores negative counts on restore", failures)

	var database = load("res://scripts/data/ItemDatabase.gd").new()
	_expect(database.load_items(), "ItemDatabase loads items.json", failures)
	_expect(database.has_item("carrot_seed"), "ItemDatabase has carrot_seed", failures)
	_expect(database.has_item("strawberry_seed"), "ItemDatabase has strawberry_seed", failures)
	_expect(database.has_item("rare_fish"), "ItemDatabase has rare_fish", failures)
	_expect(database.has_item("pet_food"), "ItemDatabase has pet_food", failures)
	_expect(not database.has_item("missing_item"), "ItemDatabase rejects missing item", failures)
	_expect(database.get_item("carrot").get("type", "") == "crop", "ItemDatabase returns carrot definition", failures)
	_expect(database.get_item("missing_item").is_empty(), "ItemDatabase returns empty missing item", failures)
	_expect(database.get_all_items().has("small_fish"), "ItemDatabase returns all item definitions", failures)
	_expect(database.get_item("small_fish").get("icon", "").contains("small_fish_icon.png"), "ItemDatabase returns fish icon path", failures)

	var crop_database = load("res://scripts/data/CropDatabase.gd").new()
	_expect(crop_database.load_crops(), "CropDatabase loads crops.json", failures)
	_expect(crop_database.has_crop("carrot"), "CropDatabase has carrot", failures)
	_expect(crop_database.has_crop("strawberry"), "CropDatabase has strawberry", failures)
	_expect(crop_database.has_crop("tomato"), "CropDatabase has tomato", failures)
	_expect(crop_database.has_crop("pumpkin"), "CropDatabase has pumpkin", failures)
	_expect(crop_database.has_crop("catnip"), "CropDatabase has catnip", failures)
	_expect(crop_database.get_crop("pumpkin").get("seed_item_id", "") == "pumpkin_seed", "CropDatabase returns pumpkin seed id", failures)
	_expect(crop_database.get_crop_for_seed("catnip_seed").get("harvest_item_id", "") == "catnip", "CropDatabase finds crop by seed", failures)
	_expect(crop_database.get_crop("missing_crop").is_empty(), "CropDatabase returns empty missing crop", failures)

	var fish_database = load("res://scripts/data/FishDatabase.gd").new()
	_expect(fish_database.load_fish(), "FishDatabase loads fish.json", failures)
	_expect(fish_database.has_spot("river"), "FishDatabase has river spot", failures)
	_expect(fish_database.has_spot("pond"), "FishDatabase has pond spot", failures)
	_expect(fish_database.has_spot("ocean"), "FishDatabase has ocean spot", failures)
	_expect(fish_database.has_spot("frozen_pond"), "FishDatabase has frozen_pond spot", failures)
	_expect(not fish_database.has_spot("lava"), "FishDatabase rejects missing spot", failures)
	var river_spot: Dictionary = fish_database.get_spot("river")
	_expect(river_spot.get("rewards", []).size() == 1, "FishDatabase keeps MVP river reward", failures)
	_expect(fish_database.get_spot("pond").get("rewards", []).size() >= 5, "FishDatabase returns expanded pond rewards", failures)
	_expect(fish_database.get_spot("lava").is_empty(), "FishDatabase returns empty missing spot", failures)
	_expect(fish_database.get_all_spots().has("river"), "FishDatabase returns all spots", failures)
	var wait_time: float = fish_database.get_wait_time_seconds("river")
	_expect(wait_time >= 2.0 and wait_time <= 4.0, "FishDatabase rolls wait time inside range", failures)
	var pond_wait_time: float = fish_database.get_wait_time_seconds("pond")
	_expect(pond_wait_time >= 3.0 and pond_wait_time <= 5.0, "FishDatabase rolls pond wait time inside range", failures)
	_expect(fish_database.get_wait_time_seconds("lava") == 0.0, "FishDatabase returns zero wait for missing spot", failures)
	fish_database.set_roll_seed(1)
	var catch_reward: Dictionary = fish_database.roll_reward("river")
	_expect(catch_reward.get("item_id", "") == "small_fish", "FishDatabase rolls small_fish reward", failures)
	_expect(int(catch_reward.get("amount", 0)) == 1, "FishDatabase rolls reward amount", failures)
	var pond_reward: Dictionary = fish_database.roll_reward("pond")
	_expect(["catfish", "sleepy_fish", "bubble_fish", "golden_fish", "rare_fish"].has(pond_reward.get("item_id", "")), "FishDatabase rolls pond reward", failures)
	_expect(fish_database.roll_reward("lava").is_empty(), "FishDatabase returns empty reward for missing spot", failures)

	var pet_database = load("res://scripts/data/PetDatabase.gd").new()
	_expect(pet_database.load_pets(), "PetDatabase loads pets.json", failures)
	_expect(pet_database.has_pet("cat"), "PetDatabase has cat", failures)
	_expect(pet_database.has_pet("dog"), "PetDatabase has dog", failures)
	_expect(pet_database.has_pet("duck"), "PetDatabase has duck", failures)
	_expect(pet_database.has_pet("bunny"), "PetDatabase has bunny", failures)
	_expect(not pet_database.has_pet("dragon"), "PetDatabase rejects missing pet", failures)
	_expect(pet_database.get_pet("cat").get("idle_asset", "").contains("cat_idle.png"), "PetDatabase returns cat art", failures)
	_expect(pet_database.get_pet("dog").get("idle_asset", "").contains("dog_idle.png"), "PetDatabase returns dog art", failures)
	_expect(pet_database.get_pet("duck").get("walk_assets", {}).get("right", "").contains("duck_walk_right.png"), "PetDatabase returns duck walk art", failures)
	_expect(pet_database.get_pet("bunny").get("favorite_item_id", "") == "carrot", "PetDatabase returns bunny favorite", failures)
	_expect(pet_database.get_pet("dragon").is_empty(), "PetDatabase returns empty missing pet", failures)
	_expect(pet_database.has_pet("eagle"), "PetDatabase has eagle", failures)
	_expect(pet_database.has_pet("penguin"), "PetDatabase has penguin", failures)
	_expect(pet_database.get_all_pets().size() == 6, "PetDatabase returns all pets", failures)
	_expect(pet_database.get_default_pet_ids() == ["cat"], "PetDatabase returns default pet ids", failures)

	var decoration_database = load("res://scripts/data/DecorationDatabase.gd").new()
	_expect(decoration_database.load_decorations(), "DecorationDatabase loads decorations.json", failures)
	_expect(decoration_database.has_decoration("fence_straight"), "DecorationDatabase has fence_straight", failures)
	_expect(decoration_database.has_decoration("pet_bed"), "DecorationDatabase has pet_bed", failures)
	_expect(decoration_database.has_decoration("garden_arch"), "DecorationDatabase has garden_arch", failures)
	_expect(decoration_database.has_decoration("fountain"), "DecorationDatabase has fountain", failures)
	_expect(not decoration_database.has_decoration("statue"), "DecorationDatabase rejects missing decoration", failures)
	_expect(decoration_database.get_decoration("bush").get("asset", "").contains("bush.png"), "DecorationDatabase returns bush asset", failures)
	_expect(decoration_database.get_decoration("statue").is_empty(), "DecorationDatabase returns empty missing decoration", failures)
	_expect(decoration_database.get_all_decorations().size() >= 13, "DecorationDatabase returns all decorations", failures)
	_expect(decoration_database.get_by_category("nature").size() >= 2, "DecorationDatabase filters by category", failures)
	_expect(decoration_database.get_by_category("light").size() >= 3, "DecorationDatabase filters light category", failures)

	var dialogue_database = load("res://scripts/data/DialogueDatabase.gd").new()
	_expect(dialogue_database.load_dialogue(), "DialogueDatabase loads dialogue.json", failures)
	_expect(dialogue_database.has_npc("farmer"), "DialogueDatabase has farmer", failures)
	_expect(dialogue_database.has_npc("fisher"), "DialogueDatabase has fisher", failures)
	_expect(dialogue_database.has_npc("shopkeeper"), "DialogueDatabase has shopkeeper", failures)
	_expect(dialogue_database.has_npc("villager"), "DialogueDatabase has villager", failures)
	_expect(dialogue_database.get_npc("farmer").get("portrait", "").contains("farmer_portrait.png"), "DialogueDatabase returns farmer portrait", failures)
	_expect(not dialogue_database.get_greeting("shopkeeper").is_empty(), "DialogueDatabase returns greeting", failures)
	_expect(dialogue_database.get_lines("fisher").size() >= 2, "DialogueDatabase returns lines", failures)
	_expect(not dialogue_database.get_time_line("farmer", "morning").is_empty(), "DialogueDatabase returns time-of-day line", failures)
	_expect(dialogue_database.get_time_line("farmer", "noon").is_empty(), "DialogueDatabase returns empty for unknown phase", failures)
	_expect(dialogue_database.get_npc("ghost").is_empty(), "DialogueDatabase returns empty missing npc", failures)

	var wallet = load("res://scripts/economy/Wallet.gd").new()
	_expect(wallet.get_money() == 50, "Wallet starts with default money", failures)
	wallet.add_money(25)
	_expect(wallet.get_money() == 75, "Wallet adds money", failures)
	_expect(wallet.spend_money(30), "Wallet spends available money", failures)
	_expect(wallet.get_money() == 45, "Wallet updates after spend", failures)
	_expect(not wallet.spend_money(100), "Wallet rejects overspend", failures)
	wallet.from_value(100)

	var shop_database = load("res://scripts/data/ShopDatabase.gd").new()
	_expect(shop_database.load_shops(), "ShopDatabase loads shop.json", failures)
	_expect(shop_database.has_shop("general_store"), "ShopDatabase has general_store", failures)
	_expect(shop_database.has_shop("fish_market"), "ShopDatabase has fish_market", failures)
	_expect(shop_database.get_buy_price("general_store", "strawberry_seed") == 12, "ShopDatabase returns buy price", failures)
	_expect(shop_database.get_sell_price("fish_market", "catfish") == 22, "ShopDatabase returns sell price", failures)
	_expect(shop_database.can_buy("general_store", "pumpkin_seed", wallet), "ShopDatabase can_buy uses wallet", failures)
	_expect(shop_database.buy_item("general_store", "pumpkin_seed", 2, inventory, wallet), "ShopDatabase buys item", failures)
	_expect(inventory.get_count("pumpkin_seed") == 2, "ShopDatabase adds bought inventory", failures)
	_expect(wallet.get_money() == 60, "ShopDatabase subtracts buy price", failures)
	inventory.add_item("catfish", 1)
	_expect(shop_database.sell_item("fish_market", "catfish", 1, inventory, wallet), "ShopDatabase sells item", failures)
	_expect(inventory.get_count("catfish") == 0, "ShopDatabase removes sold inventory", failures)
	_expect(wallet.get_money() == 82, "ShopDatabase adds sell price", failures)

	var tool_database = load("res://scripts/data/ToolDatabase.gd").new()
	_expect(tool_database.load_tools(), "ToolDatabase loads tools.json", failures)
	_expect(tool_database.has_tool("hoe"), "ToolDatabase has hoe", failures)
	_expect(tool_database.has_tool("axe"), "ToolDatabase has axe", failures)
	_expect(tool_database.has_tool("pickaxe"), "ToolDatabase has pickaxe", failures)
	_expect(tool_database.get_tool("axe").get("action_asset", "").contains("player_use_axe.png"), "ToolDatabase returns axe action", failures)
	_expect(tool_database.get_upgrade_cost("pickaxe", 2).get("items", {}).get("stone", 0) == 8, "ToolDatabase returns upgrade cost", failures)
	_expect(tool_database.get_upgrade_cost("hand", 2).is_empty(), "ToolDatabase returns empty missing upgrade", failures)
	_expect(tool_database.get_repair_cost(2) == 26, "ToolDatabase returns repair cost", failures)

	var weather_script = load("res://scripts/world/WeatherManager.gd")
	_expect(weather_script != null, "WeatherManager script exists", failures)
	var weather = null
	if weather_script != null:
		weather = weather_script.new()
		_expect(weather.call("get_weather") == "sunny", "WeatherManager starts sunny", failures)
		_expect(weather.call("is_valid_weather", "cloudy"), "WeatherManager accepts cloudy", failures)
		_expect(not weather.call("is_valid_weather", "snow"), "WeatherManager rejects unknown weather", failures)
		_expect(weather.call("set_weather", "rain"), "WeatherManager sets rain", failures)
		_expect(weather.call("get_weather") == "rain", "WeatherManager stores current weather", failures)
		_expect(bool(weather.call("waters_crops")), "Rain waters crops", failures)
		_expect(float(weather.call("get_crop_growth_multiplier")) > 1.0, "Rain speeds crop growth", failures)
		_expect(not weather.call("set_weather", "snow"), "WeatherManager rejects direct invalid weather", failures)
		weather.call("set_roll_seed", 7)
		_expect(weather.call("roll_next_weather", 2) != "", "WeatherManager rolls a next weather", failures)
		weather.call("from_dict", {"current": "storm", "next": "fog", "day": 4})
		_expect(weather.call("get_weather") == "storm", "WeatherManager restores current weather", failures)
		_expect(weather.call("get_next_weather") == "fog", "WeatherManager restores next weather", failures)
		_expect(int(weather.call("get_forecast_day")) == 4, "WeatherManager restores forecast day", failures)

	var save_manager = get_root().get_node("SaveManager")
	var autoload_inventory = get_root().get_node("Inventory")
	var autoload_wallet = get_root().get_node("Wallet")
	var autoload_weather = get_root().get_node_or_null("WeatherManager")
	save_manager.set_inventory_source(autoload_inventory)
	save_manager.set_wallet_source(autoload_wallet)
	if autoload_weather != null:
		save_manager.set_weather_source(autoload_weather)
	# --- Phase 7 living-world managers (autoloads) ---
	var friendship = get_root().get_node_or_null("PetFriendship")
	var achievements = get_root().get_node_or_null("AchievementManager")
	var seasons = get_root().get_node_or_null("SeasonManager")
	var festival_manager = get_root().get_node_or_null("FestivalManager")
	_expect(friendship != null, "PetFriendship autoload available", failures)
	_expect(achievements != null, "AchievementManager autoload available", failures)
	_expect(seasons != null, "SeasonManager autoload available", failures)
	_expect(festival_manager != null, "FestivalManager autoload available", failures)

	if friendship != null:
		friendship.call("from_dict", {})
		_expect(bool(friendship.call("likes", "bunny", "carrot")), "Friendship: bunny likes carrot", failures)
		autoload_inventory.from_dict({"carrot": 1})
		_expect(bool(friendship.call("feed", "bunny", "carrot")), "Friendship: feed consumes favorite", failures)
		_expect(int(friendship.call("get_points", "bunny")) == 25, "Friendship: favorite gives 25 points", failures)
		_expect(not bool(friendship.call("feed", "bunny", "carrot")), "Friendship: feed fails without item", failures)
		friendship.call("add_points", "cat", 300)
		_expect(int(friendship.call("get_level", "cat")) == 3, "Friendship: level derives from points", failures)
		_expect(bool(friendship.call("has_passive_ability", "cat")), "Friendship: ability unlocks at level 3", failures)

	if achievements != null:
		achievements.call("from_dict", {"progress": {}, "unlocked": []})
		achievements.call("record_event", "harvest", 1)
		_expect(bool(achievements.call("is_unlocked", "first_harvest")), "Achievement: first_harvest unlocks", failures)
		for i in range(10):
			achievements.call("record_event", "fish", 1)
		_expect(bool(achievements.call("is_unlocked", "best_fisher")), "Achievement: best_fisher at 10", failures)
		achievements.call("record_event", "friendship_level", 3)
		_expect(bool(achievements.call("is_unlocked", "animal_lover")), "Achievement: animal_lover at friendship 3", failures)

	if seasons != null:
		_expect(String(seasons.call("season_for_day", 1)) == "spring", "Season: day 1 is spring", failures)
		_expect(String(seasons.call("season_for_day", 8)) == "summer", "Season: day 8 is summer", failures)
		_expect(String(seasons.call("season_for_day", 22)) == "winter", "Season: day 22 is winter", failures)
		_expect(float(seasons.call("get_crop_growth_multiplier", "carrot")) > 0.0, "Season: crop multiplier is positive", failures)

	if festival_manager != null:
		festival_manager.call("from_dict", {})
		_expect(String(festival_manager.call("festival_for_day", 7)) == "pet_festival", "Festival: day 7 is pet_festival", failures)
		autoload_wallet.from_value(0)
		_expect(bool(festival_manager.call("claim_reward", 7)), "Festival: reward claimable", failures)
		_expect(int(autoload_wallet.get_money()) == 30, "Festival: reward grants coins", failures)
		_expect(not bool(festival_manager.call("claim_reward", 7)), "Festival: reward only once per day", failures)

	# --- Phase 9: crafting + energy ---
	var recipes = get_root().get_node_or_null("RecipeDatabase")
	var energy = get_root().get_node_or_null("EnergyManager")
	_expect(recipes != null, "RecipeDatabase autoload available", failures)
	_expect(energy != null, "EnergyManager autoload available", failures)
	if recipes != null:
		_expect(recipes.call("get_by_station", "kitchen").size() >= 1, "RecipeDatabase has kitchen recipes", failures)
		autoload_inventory.from_dict({"carrot": 1, "small_fish": 1})
		_expect(bool(recipes.call("can_craft", "pet_food", autoload_inventory)), "Recipe can_craft with ingredients", failures)
		_expect(bool(recipes.call("craft", "pet_food", autoload_inventory)), "Recipe craft succeeds", failures)
		_expect(int(autoload_inventory.call("get_count", "pet_food")) == 2, "Recipe produced output", failures)
		_expect(int(autoload_inventory.call("get_count", "carrot")) == 0, "Recipe consumed input", failures)
		_expect(not bool(recipes.call("can_craft", "pet_food", autoload_inventory)), "Recipe can_craft false without ingredients", failures)
	if energy != null:
		energy.call("set_energy", 100)
		_expect(bool(energy.call("spend", 30)), "Energy spend", failures)
		_expect(int(energy.call("get_energy")) == 70, "Energy after spend", failures)
		energy.call("restore", 10)
		_expect(int(energy.call("get_energy")) == 80, "Energy after restore", failures)
		autoload_inventory.from_dict({"pet_food": 1})
		_expect(bool(energy.call("eat", "pet_food")), "Energy eat food", failures)
		_expect(int(energy.call("get_energy")) == 100, "Energy restored by eating (clamped)", failures)
		autoload_inventory.clear()

	# --- Phase 10/11: skills, quests, collections, mail, npc relationships ---
	var skills = get_root().get_node_or_null("SkillManager")
	var quests = get_root().get_node_or_null("QuestManager")
	var collections = get_root().get_node_or_null("CollectionManager")
	var mail = get_root().get_node_or_null("MailManager")
	var npc_rel = get_root().get_node_or_null("NpcRelationship")
	_expect(skills != null, "SkillManager autoload available", failures)
	_expect(quests != null, "QuestManager autoload available", failures)
	_expect(collections != null, "CollectionManager autoload available", failures)
	_expect(mail != null, "MailManager autoload available", failures)
	_expect(npc_rel != null, "NpcRelationship autoload available", failures)
	if skills != null:
		skills.call("from_dict", {})
		skills.call("add_xp", "farming", 150)
		_expect(int(skills.call("get_level", "farming")) == 1, "Skill levels from XP", failures)
		skills.call("add_event_xp", "fish", 1)
		_expect(int(skills.call("get_xp", "fishing")) == 15, "Skill XP from event", failures)
		# Level perks (10.3)
		skills.call("from_dict", {"farming": 900, "mining": 400})
		_expect(int(skills.call("harvest_bonus")) == 3, "Skill perk: harvest bonus", failures)
		_expect(int(skills.call("gather_energy_cost", 6, "mine")) == 4, "Skill perk: mining energy discount", failures)
		skills.call("from_dict", {})
	if quests != null:
		quests.call("from_dict", {"progress": {}, "claimed": []})
		for i in range(3):
			quests.call("record_event", "harvest", 1)
		_expect(bool(quests.call("is_complete", "first_sprouts")), "Quest completes at target", failures)
		autoload_wallet.from_value(0)
		_expect(bool(quests.call("claim", "first_sprouts")), "Quest claim grants reward", failures)
		_expect(int(autoload_wallet.get_money()) == 20, "Quest reward money", failures)
		_expect(not bool(quests.call("claim", "first_sprouts")), "Quest claim only once", failures)
	if collections != null:
		collections.call("from_dict", {"collected": []})
		autoload_inventory.from_dict({"carrot": 1})
		_expect(bool(collections.call("donate", "carrot", autoload_inventory)), "Collection donate", failures)
		_expect(bool(collections.call("is_collected", "carrot")), "Collection marks collected", failures)
		_expect(Vector2i(collections.call("set_progress", "Crops")).x == 1, "Collection set progress", failures)
		# Complete the Crops set → one-time coin reward.
		autoload_wallet.from_value(0)
		autoload_inventory.from_dict({"strawberry": 1, "tomato": 1, "pumpkin": 1, "catnip": 1})
		for crop in ["strawberry", "tomato", "pumpkin", "catnip"]:
			collections.call("donate", crop, autoload_inventory)
		_expect(Vector2i(collections.call("set_progress", "Crops")).x == 5, "Collection set complete", failures)
		_expect(int(autoload_wallet.get_money()) == 50, "Collection completion reward", failures)
	if mail != null:
		mail.call("from_dict", {"mail": [{"title": "t", "body": "b", "money": 5, "items": {}, "claimed": false}], "next": 0})
		autoload_wallet.from_value(0)
		_expect(bool(mail.call("claim", 0)), "Mail claim", failures)
		_expect(int(autoload_wallet.get_money()) == 5, "Mail attachment money", failures)
		_expect(int(mail.call("unread_count")) == 0, "Mail marked read", failures)
	if npc_rel != null:
		npc_rel.call("from_dict", {})
		autoload_inventory.from_dict({"flower": 1})
		_expect(bool(npc_rel.call("gift", "farmer", "flower")), "NPC gift", failures)
		_expect(int(npc_rel.call("get_points", "farmer")) == 20, "NPC relationship points", failures)
		autoload_inventory.clear()

	var test_save_path := "user://backend_test_save_v1.json"
	_expect(save_manager.get_save_path() == "user://save_v1.json", "SaveManager exposes save path", failures)
	_expect(not save_manager.get_default_save_data().get("pets", []).is_empty(), "SaveManager returns default data", failures)
	_expect(save_manager.get_default_save_data().get("weather", {}).get("current", "") == "sunny", "SaveManager default weather is sunny", failures)
	autoload_inventory.from_dict({"carrot": 2, "small_fish": 1})
	autoload_wallet.from_value(123)
	if autoload_weather != null:
		autoload_weather.call("set_weather", "fog")
	else:
		_expect(false, "WeatherManager autoload is available", failures)
	_expect(autoload_inventory.get_count("small_fish") == 1, "Test autoload inventory is writable", failures)
	var built_save: Dictionary = save_manager.build_save_data(Vector2(120.4, 80.6))
	_expect(built_save.get("player_position", {}).get("x", 0) == 120, "SaveManager stores player x position", failures)
	_expect(built_save.get("player_position", {}).get("y", 0) == 81, "SaveManager stores player y position", failures)
	_expect(built_save.get("inventory", {}).get("small_fish", 0) == 1, "SaveManager stores inventory", failures)
	_expect(built_save.get("money", 0) == 123, "SaveManager stores wallet money", failures)
	_expect(built_save.get("weather", {}).get("current", "") == "fog", "SaveManager stores weather", failures)
	_expect(built_save.has("friendship"), "SaveManager stores friendship", failures)
	_expect(built_save.has("achievements"), "SaveManager stores achievements", failures)
	_expect(built_save.has("festivals"), "SaveManager stores festivals", failures)
	_expect(save_manager.save_data(built_save, test_save_path), "SaveManager writes save data", failures)
	_expect(save_manager.has_save(test_save_path), "SaveManager detects save file", failures)
	autoload_inventory.clear()
	autoload_wallet.from_value(0)
	if autoload_weather != null:
		autoload_weather.call("set_weather", "sunny")
	var loaded_save: Dictionary = save_manager.load_game(test_save_path)
	_expect(loaded_save.get("inventory", {}).get("carrot", 0) == 2, "SaveManager loads inventory data", failures)
	_expect(autoload_inventory.get_count("small_fish") == 1, "SaveManager applies loaded inventory", failures)
	_expect(autoload_wallet.get_money() == 123, "SaveManager applies loaded money", failures)
	if autoload_weather != null:
		_expect(autoload_weather.call("get_weather") == "fog", "SaveManager applies loaded weather", failures)
	var normalized_save: Dictionary = save_manager.load_data(test_save_path)
	_expect(normalized_save.get("money", 0) == 123, "SaveManager loads money value", failures)
	_expect(normalized_save.get("weather", {}).get("current", "") == "fog", "SaveManager loads weather value", failures)
	_expect(save_manager.load_data("user://missing_backend_test_save.json").is_empty(), "SaveManager returns empty missing save", failures)
	_expect(save_manager.load_game("user://missing_backend_test_save.json").is_empty(), "SaveManager load_game handles missing save", failures)
	autoload_inventory.clear()

	inventory.free()
	database.free()
	crop_database.free()
	fish_database.free()
	pet_database.free()
	decoration_database.free()
	dialogue_database.free()
	wallet.free()
	shop_database.free()
	tool_database.free()
	if weather != null:
		weather.free()

	if failures.is_empty():
		print("Backend smoke tests passed")
		quit(0)
	else:
		for failure in failures:
			printerr(failure)
		quit(1)


func _expect(condition: bool, message: String, failures: Array[String]) -> void:
	if not condition:
		failures.append(message)
