[gd_resource type="Theme" load_steps=7 format=3]

; Global cozy UI theme for Meow Meow ~.
; Generic panels use a clean warm "parchment" flat box (never distorts at any
; size). The important overlays (Inventory/Shop/Dialogue/Tool/Pause/Title) apply
; the decorative assets/ui frames on top via UiSkin, with margins that keep
; content inside the cream centre. Buttons are a warm flat box (the decorative
; button art doesn't 9-slice). Warm-dark readable label text.

[sub_resource type="StyleBoxFlat" id="sb_panel"]
bg_color = Color(0.965, 0.918, 0.792, 1)
border_width_left = 3
border_width_top = 3
