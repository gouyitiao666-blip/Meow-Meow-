; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Meow Meow ~"
run/main_scene="res://scenes/world/World.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://assets/pets/cat_idle.png"

[autoload]

Inventory="*res://scripts/inventory/Inventory.gd"
ItemDatabase="*res://scripts/data/ItemDatabase.gd"
CropDatabase="*res://scripts/data/CropDatabase.gd"
FishDatabase="*res://scripts/data/FishDatabase.gd"
PetDatabase="*res://scripts/data/PetDatabase.gd"
DecorationDatabase="*res://scripts/data/DecorationDatabase.gd"
DialogueDatabase="*res://scripts/data/DialogueDatabase.gd"
ShopDatabase="*res://scripts/data/ShopDatabase.gd"
ToolDatabase="*res://scripts/data/ToolDatabase.gd"
Wallet="*res://scripts/economy/Wallet.gd"
SaveManager="*res://scripts/save/SaveManager.gd"

[display]

window/stretch/mode="canvas_items"

